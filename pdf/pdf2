<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sesi 2 — Mengelola PDF</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --red:      #C0392B;
    --red-light:#E74C3C;
    --red-pale: #FDECEA;
    --ink:      #1A1A1A;
    --ink-2:    #444444;
    --ink-3:    #777777;
    --paper:    #FAFAF8;
    --white:    #FFFFFF;
    --border:   #E5E2DD;
    --accent:   #2C3E50;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--paper);
    color: var(--ink);
    font-size: 15px;
    line-height: 1.7;
  }

  /* ── HERO ── */
  .hero {
    background: var(--accent);
    color: var(--white);
    padding: 60px 40px 50px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "PDF";
    position: absolute;
    right: -20px;
    top: -30px;
    font-family: 'Sora', sans-serif;
    font-size: 180px;
    font-weight: 800;
    color: rgba(255,255,255,0.05);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }
  .hero-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }
  .hero-nav a {
    color: rgba(255,255,255,0.5);
    font-size: 12px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .hero-nav a:hover { color: rgba(255,255,255,0.85); }
  .hero-nav span { color: rgba(255,255,255,0.3); font-size: 12px; }
  .hero-label {
    display: inline-block;
    background: var(--red);
    color: var(--white);
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 2px;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: 'Sora', sans-serif;
    font-size: clamp(26px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    max-width: 580px;
    margin-bottom: 14px;
  }
  .hero h1 span { color: var(--red-light); }
  .hero > p {
    color: rgba(255,255,255,0.7);
    max-width: 520px;
    font-size: 15px;
  }
  .hero-meta {
    display: flex;
    gap: 24px;
    margin-top: 30px;
    flex-wrap: wrap;
  }
  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.6);
    font-size: 13px;
  }
  .hero-meta-item strong { color: var(--white); font-weight: 600; }
  .icon-sm {
    width: 16px; height: 16px;
    fill: none; stroke: currentColor;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    flex-shrink: 0;
  }

  /* ── LAYOUT ── */
  .page { max-width: 820px; margin: 0 auto; padding: 48px 24px 80px; }

  /* ── SECTION TITLE ── */
  .section-title {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 10px;
  }
  h2 {
    font-family: 'Sora', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 20px;
    line-height: 1.3;
  }
  h3 {
    font-family: 'Sora', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 6px;
  }
  p { color: var(--ink-2); margin-bottom: 10px; }

  /* ── DIVIDER ── */
  .divider { border: none; border-top: 1px solid var(--border); margin: 40px 0; }

  /* ── TUJUAN GRID ── */
  .tujuan-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }
  .tujuan-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 18px 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .tujuan-num {
    font-family: 'Sora', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--red);
    line-height: 1;
    flex-shrink: 0;
  }
  .tujuan-card p { color: var(--ink-2); font-size: 14px; margin: 0; }

  /* ── OPERASI CARDS ── */
  .operasi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-top: 8px;
  }
  .operasi-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .operasi-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px 14px;
    border-bottom: 1px solid var(--border);
  }
  .operasi-icon {
    width: 40px; height: 40px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .operasi-header h3 { margin: 0; font-size: 15px; }
  .operasi-body { padding: 14px 18px 18px; }
  .operasi-body p { font-size: 13px; color: var(--ink-2); margin-bottom: 10px; }
  .operasi-usecase {
    font-size: 12px;
    color: var(--ink-3);
    font-style: italic;
    border-left: 3px solid var(--border);
    padding-left: 10px;
    margin: 0;
  }

  /* ── INFO BOX ── */
  .info-box {
    background: var(--white);
    border: 1px solid var(--border);
    border-left: 4px solid var(--red);
    border-radius: 6px;
    padding: 18px 22px;
    margin: 18px 0;
  }
  .info-box.blue  { border-left-color: #2980B9; }
  .info-box.green { border-left-color: #27AE60; }
  .info-box.orange{ border-left-color: #E67E22; }
  .info-box-label {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 6px;
  }
  .info-box.blue  .info-box-label { color: #2980B9; }
  .info-box.green .info-box-label { color: #27AE60; }
  .info-box.orange .info-box-label { color: #E67E22; }
  .info-box p { margin: 0; font-size: 14px; }

  /* ── STEP LIST ── */
  .step-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 8px; }
  .step-list li {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 14px 18px;
  }
  .step-num {
    background: var(--accent);
    color: var(--white);
    font-family: 'Sora', sans-serif;
    font-size: 12px;
    font-weight: 700;
    width: 26px; height: 26px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .step-list li > div { flex: 1; }
  .step-list li h3 { font-size: 14px; margin-bottom: 3px; }
  .step-list li p  { margin: 0; font-size: 13px; color: var(--ink-3); }
  .step-list li code {
    background: #F0EFED;
    color: var(--red);
    font-size: 12px;
    padding: 1px 6px;
    border-radius: 3px;
    font-family: 'Courier New', monospace;
  }

  /* ── TOOLS TABLE ── */
  .tools-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
    margin-top: 8px;
  }
  .tools-table th {
    background: var(--accent);
    color: var(--white);
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-align: left;
    padding: 10px 16px;
  }
  .tools-table td {
    padding: 11px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--ink-2);
    vertical-align: top;
  }
  .tools-table tr:last-child td { border-bottom: none; }
  .tools-table tr:nth-child(even) td { background: #F7F5F2; }
  .badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 10px;
  }
  .badge-green  { background: #EAFAF1; color: #1E8449; }
  .badge-red    { background: var(--red-pale); color: var(--red); }
  .badge-blue   { background: #EBF5FB; color: #2980B9; }
  .badge-orange { background: #FEF9E7; color: #B7770D; }

  /* ── PERBANDINGAN KOMPRESI ── */
  .compress-visual {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 22px 24px;
    margin-top: 16px;
  }
  .compress-visual h3 { font-size: 14px; margin-bottom: 14px; color: var(--ink-3); font-weight: 600; }
  .compress-bar-wrap { margin-bottom: 12px; }
  .compress-label {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--ink-3);
    margin-bottom: 4px;
  }
  .compress-label strong { color: var(--ink); }
  .compress-track {
    background: #EDEBE8;
    border-radius: 4px;
    height: 10px;
    overflow: hidden;
  }
  .compress-fill {
    height: 10px;
    border-radius: 4px;
    transition: width 0.5s ease;
  }

  /* ── LATIHAN BOX ── */
  .latihan-box {
    background: var(--accent);
    color: var(--white);
    border-radius: 8px;
    padding: 26px 28px;
    margin-top: 8px;
  }
  .latihan-box h3 {
    color: var(--white);
    font-family: 'Sora', sans-serif;
    font-size: 16px;
    margin-bottom: 6px;
  }
  .latihan-box > p { color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 14px; }
  .latihan-steps { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .latihan-steps li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    color: rgba(255,255,255,0.88);
    align-items: flex-start;
  }
  .latihan-steps li::before {
    content: "→";
    color: var(--red-light);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .tugas-box {
    background: var(--red-pale);
    border: 1.5px solid #F5C6C2;
    border-radius: 8px;
    padding: 22px 24px;
    margin-top: 14px;
  }
  .tugas-box h3 { color: var(--red); font-size: 15px; margin-bottom: 10px; }
  .tugas-box ul { padding-left: 18px; }
  .tugas-box ul li { font-size: 14px; color: var(--ink-2); margin-bottom: 6px; }

  /* ── RINGKASAN ── */
  .ringkasan-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 10px;
  }
  .ringkasan-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px;
    text-align: center;
  }
  .ringkasan-icon { font-size: 26px; margin-bottom: 8px; }
  .ringkasan-card p { font-size: 13px; color: var(--ink-2); margin: 0; line-height: 1.5; }

  /* ── NAV SESI ── */
  .nav-sesi {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 8px 16px;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    background: var(--white);
    transition: border-color 0.15s, background 0.15s;
  }
  .nav-btn:hover { border-color: var(--accent); background: #F0F0EE; }
  .nav-btn svg {
    width: 14px; height: 14px;
    fill: none; stroke: currentColor;
    stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
  }
  .nav-center {
    font-size: 12px;
    color: var(--ink-3);
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--accent);
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 18px 20px;
    font-size: 12px;
  }
  footer strong { color: rgba(255,255,255,0.8); }

  @media (max-width: 600px) {
    .hero { padding: 40px 20px 36px; }
    .hero::before { font-size: 110px; }
    .page { padding: 32px 16px 60px; }
    .operasi-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
