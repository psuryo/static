      </div>
      <div class="compress-track">
        <div class="compress-fill" style="width:47%; background:#2980B9;"></div>
      </div>
    </div>

    <div class="compress-bar-wrap">
      <div class="compress-label">
        <span style="color:#27AE60;">Setelah Strong Compression</span>
        <span>~2.5 MB (−83%)</span>
      </div>
      <div class="compress-track">
